# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
APP_NAME=Briefing 7
APP_URL=http://localhost:3000
# Secret used to authenticate Vercel Cron and /api/test-briefing calls
CRON_SECRET=your_cron_secret_here
TIMEZONE=Europe/Paris

# Briefing limits
MAX_BRIEFING_WORDS=1200
MAX_WHATSAPP_CHARS_PER_MESSAGE=1800
MAX_WHATSAPP_MESSAGES=9

# ─────────────────────────────────────────────
# Supabase — server side ONLY, never expose to client
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─────────────────────────────────────────────
# Twilio — WhatsApp
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio sandbox number or approved WhatsApp sender
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your personal WhatsApp number (international format)
WHATSAPP_TO=whatsapp:+33600000000

# ─────────────────────────────────────────────
# AI Provider — choose "anthropic" or "openai"
# ─────────────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
OPENAI_API_KEY=sk-your_openai_key
# Model to use, e.g. claude-sonnet-4-6 or gpt-4o
AI_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────
# Search Provider — choose "tavily", "brave", or "serper"
# ─────────────────────────────────────────────
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=your_search_api_key

# ─────────────────────────────────────────────
# Runtime
# ─────────────────────────────────────────────
NODE_ENV=development
